            document.getElementById('customer').value = customer;
            document.getElementById('localbody').value = localbody;
            document.getElementById('ward').value = ward;
            document.getElementById('location').value = location;
            document.getElementById('number_of_bags').value = numberOfBags;
            document.getElementById('building_no').value = buildingNo;
            document.getElementById('street_name').value = streetName;
            document.getElementById('kg').value = kg;
            document.getElementById('scheduled_date').value = scheduledDate.includes('-') ? scheduledDate.split(' ')[0] : '';
            document.getElementById('collection_time').value = collectionTime.includes(':') ? collectionTime : '';

            // Store the ID for update
            document.getElementById('crudForm').dataset.recordId = id;
            document.getElementById('modalTitle').textContent = 'Edit Waste Collection Record';

            // Show the modal
            // Show the modal
            document.getElementById('crudModal').style.display = 'flex';
