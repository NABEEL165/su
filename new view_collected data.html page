        // CRUD Functions
        function editRecord(id) {
            // Get the row data
            const row = document.getElementById(`row-${id}`);
            if (!row) return;

            // Extract data from the row
            const cells = row.querySelectorAll('td');
            const customer = cells[0].textContent;
