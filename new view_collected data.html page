    <script>
        const menuToggle = document.getElementById('menuToggle');
        const navbarLinks = document.getElementById('navbarLinks');

        menuToggle.addEventListener('click', () => {
            menuToggle.classList.toggle('active');
            navbarLinks.classList.toggle('active');
        });

        // Close mobile menu when window is resized to desktop view
        window.addEventListener('resize', () => {
            if (window.innerWidth > 768) {
                navbarLinks.classList.remove('active');
                menuToggle.classList.remove('active');
            }
        });

        document.addEventListener('DOMContentLoaded', function () {
            // Calculate and display stats
            calculateStats();

            // Add loading animation for back button
            const backButton = document.querySelector('.btn-secondary');
            backButton.addEventListener('click', function (e) {
                document.getElementById('loadingOverlay').style.display = 'flex';
            });

            // Add hover effects to table rows
            const tableRows = document.querySelectorAll('table tr:not(:first-child)');
            tableRows.forEach((row, index) => {
                row.addEventListener('mouseenter', function () {
                    this.style.transform = 'scale(1.01)';
                });

                row.addEventListener('mouseleave', function () {
                    this.style.transform = 'scale(1)';
                });

                // Add staggered fade-in animation
                row.style.opacity = '0';
                row.style.animation = `fadeInUp 0.6s ease forwards ${index * 0.1}s`;
            });

            // Add animation to mobile cards
            const cards = document.querySelectorAll('.card');
            cards.forEach((card, index) => {
                card.style.opacity = '0';
                card.style.animation = `fadeInUp 0.6s ease forwards ${index * 0.1}s`;
            });
        });

        function calculateStats() {
            const rows = document.querySelectorAll('table tr:not(:first-child)');
            let totalKG = 0;
            let totalAmount = 0;
            const collectors = new Set();

            rows.forEach(row => {
                const cells = row.querySelectorAll('td');
                if (cells.length > 0) {
                    // Based on the table structure in the template
                    // Customer is at index 0, Collector is at index 8, KG at index 5, Amount at index 7
                    const collector = cells[8].textContent.replace('👤', '').trim();
                    const kg = parseFloat(cells[5].textContent) || 0;
                    const amount = parseFloat(cells[7].textContent.replace('₹', '')) || 0;

                    collectors.add(collector);
                    totalKG += kg;
                    totalAmount += amount;
                }
            });

            // Update stats with animation
            animateCounter('totalRecords', rows.length);
            animateCounter('totalKG', totalKG, 'KG', true);
            animateCounter('totalAmount', totalAmount, '₹', true);
            animateCounter('activeCollectors', collectors.size);
        }

        // Filter form handling
        document.getElementById('filterForm').addEventListener('submit', function(e) {
            e.preventDefault();
            applyFilters();
        });

        // Clear filters
        document.getElementById('clearFilters').addEventListener('click', function() {
            document.getElementById('district').value = '';
            document.getElementById('localbody').value = '';
            document.getElementById('phone').value = '';
            document.getElementById('from_date').value = '';
            document.getElementById('to_date').value = '';
            applyFilters();
        });

        // Apply filters function
        function applyFilters() {
            const formData = new FormData(document.getElementById('filterForm'));
            const params = new URLSearchParams();
            
            for (let [key, value] of formData.entries()) {
                if (value) {
                    params.append(key, value);
                }
            }
            
            const url = '{% url "super_admin_dashboard:view_collected_data" %}?' + params.toString();
            
            // Show loading state
            document.getElementById('loadingOverlay').style.display = 'flex';
            
            // Make AJAX request
            fetch(url, {
                method: 'GET',
                headers: {
                    'X-Requested-With': 'XMLHttpRequest',
                    'Content-Type': 'application/json',
                }
            })
            .then(response => response.json())
            .then(data => {
                updateTable(data.data);
                updateStats(data.data);
                document.getElementById('loadingOverlay').style.display = 'none';
            })
            .catch(error => {
                console.error('Error:', error);
                document.getElementById('loadingOverlay').style.display = 'none';
                // Fallback to regular page reload
                window.location.href = url;
            });
        }

        // Update table with filtered data
        function updateTable(data) {
            const tbody = document.querySelector('tbody');
            const mobileCards = document.querySelector('.mobile-cards');
            
            if (!tbody && !mobileCards) return;
            
            // Update desktop table
            if (tbody) {
                tbody.innerHTML = '';
                
                if (data.length === 0) {
                    tbody.innerHTML = `
                        <tr>
                            <td colspan="17" style="text-align: center; padding: 50px; color: #6c757d; font-size: 1.2rem;">
                                <i class="fas fa-database" style="font-size: 3rem; margin-bottom: 15px; display: block; color: #ced4da;"></i>
                                No waste collection data found matching the filters
                            </td>
                        </tr>
                    `;
                } else {
                    data.forEach(item => {
                        const row = document.createElement('tr');
                        row.id = `row-${item.id}`;
                        row.innerHTML = `
                            <td>${item.customer}</td>
                            <td>${item.localbody || '<span style="color: #6c757d; font-style: italic;">Not assigned</span>'}</td>
                            <td>${item.ward}</td>
                            <td>${item.location}</td>
                            <td style="font-weight: 600; color: #4CAF50;">${item.number_of_bags}</td>
                            <td style="font-weight: 600; color: #2196F3;">${item.kg}</td>
                            <td>${item.scheduled_date || '<span style="color: #6c757d; font-style: italic;">Not scheduled</span>'}</td>
                            <td style="font-weight: 700; color: #e91e63;">₹${item.total_amount}</td>
                            <td>${item.payment_method}</td>
                            <td style="font-weight: 600; color: #673AB7;">
                                <i class="fas fa-user-shield"></i> ${item.collector}
                            </td>
                            <td>${item.building_no}</td>
                            <td>${item.street_name}</td>
                            <td>
                                ${item.photo_url ? 
                                    `<img src="${item.photo_url}" alt="Photo" onclick="openModal('${item.photo_url}')">` : 
                                    '<span style="color: #6c757d; font-style: italic;">No Image</span>'
                                }
                            </td>
                            <td>${item.booking_date}</td>
                            <td>${item.collection_time || '<span style="color: #6c757d; font-style: italic;">Not recorded</span>'}</td>
                            <td>${item.created_at}</td>
                            <td class="actions-column">
                                <button class="action-btn delete-btn" onclick="deleteRecord(${item.id})">
                                    <i class="fas fa-trash"></i> Delete
                                </button>
                            </td>
                        `;
                        tbody.appendChild(row);
                    });
                }
            }
            
            // Update mobile cards
            if (mobileCards) {
                mobileCards.innerHTML = '';
                
                if (data.length === 0) {
                    mobileCards.innerHTML = `
                        <div style="text-align: center; padding: 50px; color: #6c757d; font-size: 1.2rem;">
                            <i class="fas fa-database" style="font-size: 3rem; margin-bottom: 15px; display: block; color: #ced4da;"></i>
                            No waste collection data found matching the filters
                        </div>
                    `;
                } else {
                    data.forEach(item => {
                        const card = document.createElement('div');
                        card.className = 'card';
                        card.id = `card-${item.id}`;
                        card.innerHTML = `
                            <div class="card-header">
                                <span>👤 ${item.collector}</span>
                                <span>${new Date(item.created_at).toLocaleDateString()}</span>
                            </div>
                            <div class="card-body">
                                <div class="card-row">
                                    <div class="card-label">👤 Customer</div>
                                    <div class="card-value">${item.customer}</div>
                                </div>
                                <div class="card-row">
                                    <div class="card-label">🏛️ Local Body</div>
                                    <div class="card-value">${item.localbody || '<span style="color: #6c757d; font-style: italic;">Not assigned</span>'}</div>
                                </div>
                                <div class="card-row">
                                    <div class="card-label">🏘️ Ward</div>
                                    <div class="card-value">${item.ward}</div>
                                </div>
                                <div class="card-row">
                                    <div class="card-label">📍 Location</div>
                                    <div class="card-value">${item.location}</div>
                                </div>
                                <div class="card-row">
                                    <div class="card-label">🛍️ Bags</div>
                                    <div class="card-value">${item.number_of_bags}</div>
                                </div>
                                <div class="card-row">
                                    <div class="card-label">⚖️ Weight</div>
                                    <div class="card-value weight">${item.kg} KG</div>
                                </div>
