            const ward = cells[2].textContent;
            const location = cells[3].textContent;
            const numberOfBags = cells[4].textContent;
            const kg = cells[5].textContent;
            const scheduledDate = cells[6].textContent.replace('Not scheduled', '').trim();
            const totalAmount = cells[7].textContent.replace('₹', '').trim();
            const collector = cells[8].textContent.replace('👤 ', '').replace('👤', '').trim();
            const buildingNo = cells[9].textContent;
            const streetName = cells[10].textContent;
