        // Update statistics
        function updateStats(data) {
            const totalCollections = data.length;
            const totalWeight = data.reduce((sum, item) => sum + parseFloat(item.kg || 0), 0);
            const totalAmount = data.reduce((sum, item) => sum + parseFloat(item.total_amount || 0), 0);
            const collectors = new Set(data.map(item => item.collector)).size;
            
            // Update stat cards
            animateCounter('totalRecords', totalCollections);
            animateCounter('totalKG', totalWeight, 'KG', true);
            animateCounter('totalAmount', totalAmount, '₹', true);
            animateCounter('activeCollectors', collectors);
        }

        function animateCounter(elementId, targetValue, suffix = '', isDecimal = false) {
            const element = document.getElementById(elementId);
            const startValue = 0;
            const duration = 2000;
            const startTime = performance.now();

            function updateCounter(currentTime) {
                const elapsedTime = currentTime - startTime;
                const progress = Math.min(elapsedTime / duration, 1);

                const easeOutCubic = 1 - Math.pow(1 - progress, 3);
                const currentValue = startValue + (targetValue - startValue) * easeOutCubic;

                const displayValue = isDecimal ? currentValue.toFixed(2) : Math.floor(currentValue);

                element.textContent =
                    suffix === '₹' ? `₹${displayValue}` :
                        suffix === 'KG' ? `${displayValue} KG` :
                            displayValue;

                if (progress < 1) {
                    requestAnimationFrame(updateCounter);
                }
            }

            requestAnimationFrame(updateCounter);
        }

