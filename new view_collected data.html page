<!DOCTYPE html>
{% load static %}
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Collected Waste Records - SuchiGo</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }


        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #e8f5e8 0%, #e1f3f8 100%);
            min-height: 100vh;

            display: flex;
            align-items: center;
            flex-direction: column;
            justify-content: center;
        }

        .navbar {
            background: linear-gradient(135deg, #000000 0%, #1a1a1a 100%);
            padding: 1rem 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.5);
            border-bottom: 1px solid #333;
            position: sticky;
            top: 0;
            z-index: 1000;
            width: 100%;
        }

        .navbar-left {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .navbar-logo {
            width: 40px;
            height: 40px;
            border-radius: 8px;
            background: linear-gradient(135deg, #666, #999);
            padding: 4px;
            transition: transform 0.3s ease;
        }

        .navbar-logo:hover {
            transform: scale(1.1) rotate(5deg);
        }

        .logo-text {
            font-size: 1.5rem;
            font-weight: 700;
            color: #ffffff;
            letter-spacing: 1px;
            background: linear-gradient(135deg, #ffffff, #999999);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .navbar-links {
            display: flex;
            list-style: none;
            gap: 2rem;
            align-items: center;
        }

        .navbar-links a {
            color: #cccccc;
            text-decoration: none;
            font-weight: 500;
            font-size: 1rem;
            padding: 0.5rem 1rem;
            border-radius: 8px;
            transition: all 0.3s ease;
            position: relative;
        }

        .navbar-links a::before {
            content: '';
            position: absolute;
            bottom: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 0;
            height: 2px;
            background: linear-gradient(90deg, #666, #999);
            transition: width 0.3s ease;
        }

        .navbar-links a:hover {
            color: #ffffff;
            background: rgba(255, 255, 255, 0.05);
        }

        .navbar-links a:hover::before {
            width: 80%;
        }

        .navbar-links a.active {
            color: #ffffff;
            background: rgba(255, 255, 255, 0.1);
            border: 1px solid rgba(255, 255, 255, 0.2);
        }

        .navbar-links a.active::before {
            width: 80%;
        }

        /* Mobile Menu Toggle */
        .menu-toggle {
            display: none;
            flex-direction: column;
            gap: 4px;
            cursor: pointer;
            padding: 8px;
            background: rgba(255, 255, 255, 0.05);
            border-radius: 8px;
            transition: all 0.3s ease;
        }

        .menu-toggle:hover {
            background: rgba(255, 255, 255, 0.1);
        }

        .menu-toggle span {
            width: 25px;
            height: 3px;
            background: #ffffff;
            border-radius: 2px;
            transition: all 0.3s ease;
        }

        .menu-toggle.active span:nth-child(1) {
            transform: rotate(45deg) translate(5px, 5px);
        }

        .menu-toggle.active span:nth-child(2) {
            opacity: 0;
        }

        .menu-toggle.active span:nth-child(3) {
            transform: rotate(-45deg) translate(7px, -6px);
        }

        /* Mobile Responsive */
        @media (max-width: 768px) {
            .navbar {
                padding: 1rem;
                flex-wrap: wrap;
            }

            .menu-toggle {
                display: flex;
                order: 3;
            }

            .navbar-left {
                flex: 1;
            }

            .navbar-links {
                flex-direction: column;
                width: 100%;
                max-height: 0;
                overflow: hidden;
                gap: 0;
                order: 4;
                background: rgba(0, 0, 0, 0.95);
                margin: 1rem -1rem -1rem;
                padding: 0 1rem;
                border-radius: 0 0 12px 12px;
                transition: max-height 0.3s ease, padding 0.3s ease;
            }

            .navbar-links.active {
                max-height: 300px;
                padding: 1rem;
                border-top: 1px solid #333;
            }

            .navbar-links li {
                width: 100%;
            }

            .navbar-links a {
                display: block;
                width: 100%;
                padding: 1rem;
                text-align: center;
                border-bottom: 1px solid rgba(255, 255, 255, 0.05);
            }

            .navbar-links li:last-child a {
                border-bottom: none;
            }

            .logo-text {
                font-size: 1.25rem;
            }

            .navbar-logo {
                width: 35px;
                height: 35px;
            }
        }

        /* Modal Styling */
        #confirmModal,
        #crudModal,
        #imageModal {
            display: none;
            position: fixed;
            z-index: 10000;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.8);
            backdrop-filter: blur(5px);
            align-items: center;
            justify-content: center;
            padding: 15px;
            /* Added padding to prevent edge touching on small screens */
        }

        #confirmModalContent,
        #crudModalContent {
            position: relative;
            /* Changed from absolute to relative for Flexbox */
            background: white;
            border-radius: 15px;
            padding: 30px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
            max-height: 90vh;
            overflow-y: auto;
            width: 90%;
            max-width: 400px;
            margin: auto;
            /* Important for flex centering */
            animation: zoomIn 0.3s ease;
        }

        #crudModalContent {
            max-width: 600px;
        }

        @keyframes zoomIn {
            from {
                opacity: 0;
                transform: scale(0.9);
            }

            to {
                opacity: 1;
                transform: scale(1);
            }
        }

        /* Close Button Style */
        .modal-close {
            position: absolute;
            top: 15px;
            right: 15px;
            color: #666;
            font-size: 24px;
            cursor: pointer;
            background: rgba(0, 0, 0, 0.05);
            border-radius: 50%;
            width: 32px;
            height: 32px;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s ease;
            z-index: 10;
        }

        .modal-close:hover {
            background: rgba(0, 0, 0, 0.1);
            color: #333;
            transform: rotate(90deg);
        }

        /* Mobile Specific Adjustments */
        @media (max-width: 576px) {

            #confirmModalContent,
            #crudModalContent {
                padding: 20px;
                width: 95%;
            }
        }


        .container {
            max-width: 1400px;
            width: 100%;
            background: rgba(255, 255, 255, 0.95);
            border-radius: 20px;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
            overflow: hidden;
            backdrop-filter: blur(10px);
            margin: auto;
        }

        .header {
            background: linear-gradient(135deg, #4CAF50 0%, #2196F3 100%);
            color: white;
            padding: 30px 20px;
            text-align: center;
            position: relative;
            overflow: hidden;
        }

        .header::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: repeating-linear-gradient(45deg,
                    transparent,
                    transparent 10px,
                    rgba(255, 255, 255, 0.05) 10px,
                    rgba(255, 255, 255, 0.05) 20px);
            animation: movePattern 20s linear infinite;
        }

        @keyframes movePattern {
            0% {
                transform: translate(-50%, -50%) rotate(0deg);
            }

            100% {
                transform: translate(-50%, -50%) rotate(360deg);
            }
        }

        .brand-title {
            font-size: clamp(1.5rem, 4vw, 2.2rem);
            margin-bottom: 5px;
            position: relative;
            z-index: 1;
            font-weight: 700;
            letter-spacing: -0.5px;
        }

        .brand-tagline {
            font-size: clamp(0.8rem, 2vw, 1rem);
            opacity: 0.9;
            position: relative;
            z-index: 1;
            font-weight: 400;
            margin-bottom: 15px;
        }

        h2 {
            font-size: clamp(1.2rem, 3vw, 1.8rem);
            position: relative;
            z-index: 1;
            opacity: 0.95;
            font-weight: 600;
        }

        .content {
            padding: 20px;
        }

        .table-container {
            background: white;
            border-radius: 15px;
            padding: 0;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.08);
            border: 2px solid #e9ecef;
            overflow: hidden;
            margin-bottom: 30px;
        }

        /* Desktop Table Styles */
        .desktop-table {
            display: block;
        }

        .mobile-cards {
            display: none;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin: 0;
            background: white;
        }

        table th {
            background: linear-gradient(135deg, #f8f9fa 0%, #e3f2fd 100%);
            color: #2c3e50;
            font-weight: 600;
            padding: 15px 10px;
            text-align: left;
            border-bottom: 2px solid #2196F3;
            font-size: clamp(0.7rem, 1.5vw, 0.9rem);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            position: sticky;
            top: 0;
            z-index: 10;
        }

        table td {
            padding: 12px 10px;
            border-bottom: 1px solid #e9ecef;
            color: #2c3e50;
            vertical-align: middle;
            font-size: clamp(0.75rem, 1.5vw, 0.95rem);
            word-wrap: break-word;
            max-width: 150px;
        }

        table tr {
            transition: all 0.3s ease;
        }

        table tr:hover {
            background: linear-gradient(135deg, #f8f9fa 0%, #e3f2fd 100%);
            transform: scale(1.01);
            box-shadow: 0 2px 8px rgba(33, 150, 243, 0.1);
        }

        table tr:nth-child(even) {
            background: #fafafa;
        }

        table tr:nth-child(even):hover {
            background: linear-gradient(135deg, #f0f0f0 0%, #e1f5fe 100%);
        }

        .actions-column {
            width: 150px;
        }

        .action-btn {
            padding: 5px 10px;
            margin: 2px;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            font-size: 0.8rem;
            display: inline-flex;
            align-items: center;
            gap: 4px;
        }

        .edit-btn {
            background: #ffc107;
            color: #212529;
        }

        .delete-btn {
            background: #dc3545;
            color: white;
        }

        .action-btn:hover {
            opacity: 0.9;
            transform: scale(1.05);
        }

        /* Mobile Card Styles */
        .card {
            background: white;
            border-radius: 15px;
            margin-bottom: 20px;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.08);
            border: 1px solid #e9ecef;
            overflow: hidden;
            transition: all 0.3s ease;
        }

        .card:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.12);
        }

        .card-header {
            background: linear-gradient(135deg, #4CAF50 0%, #2196F3 100%);
            color: white;
            padding: 15px 20px;
            font-weight: 600;
            font-size: 1.1rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .card-body {
            padding: 20px;
        }

        .card-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 10px 0;
            border-bottom: 1px solid #f0f0f0;
        }

        .card-row:last-child {
            border-bottom: none;
        }

        .card-label {
            font-weight: 600;
            color: #6c757d;
            font-size: 0.9rem;
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .card-value {
            color: #2c3e50;
            font-size: 0.95rem;
            word-wrap: break-word;
            text-align: right;
            max-width: 60%;
        }

        .card-value.amount {
            font-weight: 600;
            color: #4CAF50;
            font-size: 1.1rem;
        }

        .card-value.weight {
            font-weight: 600;
            color: #2196F3;
        }

        /* Responsive table */
        .table-wrapper {
            overflow-x: auto;
            border-radius: 15px;
        }

        /* Image styling */
        table img,
        .card-image img {
            width: 50px;
            height: 50px;
            object-fit: cover;
            border-radius: 8px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
            transition: all 0.3s ease;
            cursor: pointer;
        }

        .card-image img {
            width: 80px;
            height: 80px;
        }

        table img:hover,
        .card-image img:hover {
            transform: scale(1.1);
            z-index: 100;
            position: relative;
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.3);
        }

        /* Amount styling */
        td:nth-child(8) {
            font-weight: 600;
            color: #4CAF50;
            font-size: clamp(0.85rem, 1.5vw, 1rem);
        }

        /* KG styling */
        td:nth-child(7) {
            font-weight: 600;
            color: #2196F3;
        }

        /* No records message */
        p[style*="text-align:center"] {
            background: linear-gradient(135deg, #ffebee 0%, #fce4ec 100%);
            border: 2px solid #e74c3c;
            border-radius: 10px;
            padding: 30px;
            margin: 20px 0;
            font-size: clamp(1rem, 2vw, 1.2rem);
            font-weight: 500;
            color: #e74c3c !important;
            text-align: center !important;
        }

        /* Back button styling */
        .btn-secondary {
            background: linear-gradient(135deg, #6c757d 0%, #5a6268 100%);
            color: white;
            padding: 15px 30px;
            border: none;
            border-radius: 10px;
            font-size: clamp(1rem, 2vw, 1.1rem);
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-width: 180px;
            box-shadow: 0 4px 15px rgba(108, 117, 125, 0.3);
            margin-top: 20px;
            width: 100%;
            text-align: center;
        }

        .btn-secondary:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(108, 117, 125, 0.4);
            text-decoration: none;
            color: white;
        }

        /* Stats cards */
        .stats-container {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 15px;
            margin-bottom: 30px;
        }

        .stat-card {
            background: linear-gradient(135deg, #ffffff 0%, #f8f9fa 100%);
            border-radius: 15px;
            padding: 20px 15px;
            text-align: center;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.08);
            border-left: 5px solid #2196F3;
            transition: all 0.3s ease;
        }

        .stat-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
        }

        .stat-number {
            font-size: clamp(1.2rem, 3vw, 2rem);
            font-weight: 700;
            color: #2196F3;
            margin-bottom: 5px;
            word-wrap: break-word;
        }

        .stat-label {
            font-size: clamp(0.7rem, 1.5vw, 0.9rem);
            color: #6c757d;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        /* Mobile responsiveness */
        @media (max-width: 1024px) {
            body {
                padding: 15px;
            }

            .container {
                border-radius: 15px;
            }

            .content {
                padding: 15px;
            }

            table th,
            table td {
                padding: 8px 5px;
                font-size: 0.8rem;
            }

            table img {
                width: 40px;
                height: 40px;
            }
        }

        @media (max-width: 768px) {
            body {
                padding: 10px;
                align-items: flex-start;
                min-height: auto;
            }

            .container {
                border-radius: 10px;
                margin-top: 10px;
            }

            .header {
                padding: 20px 15px;
            }

            .content {
                padding: 15px;
            }

            .desktop-table {
                display: none;
            }

            .mobile-cards {
                display: block;
            }

            .stats-container {
                grid-template-columns: repeat(2, 1fr);
                gap: 10px;
            }

            .stat-card {
                padding: 15px 10px;
            }

            .btn-secondary {
                min-width: auto;
                margin-top: 15px;
            }
        }

        @media (max-width: 480px) {
            .stats-container {
                grid-template-columns: 1fr 1fr;
                gap: 8px;
            }

            .stat-card {
                padding: 12px 8px;
            }

            .card-body {
                padding: 15px;
            }

            .card-header {
                padding: 12px 15px;
                font-size: 1rem;
            }

            .card-label {
                font-size: 0.8rem;
            }

            .card-value {
                font-size: 0.85rem;
            }
        }

        /* Loading animation */
        .loading-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(255, 255, 255, 0.9);
            display: none;
            justify-content: center;
            align-items: center;
            z-index: 9999;
        }

        .loading-spinner {
            width: 50px;
            height: 50px;
            border: 5px solid #e3f2fd;
            border-top: 5px solid #2196F3;
            border-radius: 50%;
            animation: spin 1s linear infinite;
        }

        @keyframes spin {
            0% {
                transform: rotate(0deg);
            }

            100% {
                transform: rotate(360deg);
            }
        }

        /* Highlight animations */
        .highlight-row {
            animation: highlightPulse 2s ease-in-out;
        }

        @keyframes highlightPulse {

            0%,
            100% {
                background: transparent;
            }

            50% {
                background: linear-gradient(135deg, #e8f5e8 0%, #e3f2fd 100%);
            }
        }

        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        @media print {
    .navbar,
    .menu-toggle,
    button,
    .actions-column {
        display: none !important;
    }

    body {
        background: white !important;
    }

    .container {
        box-shadow: none !important;
        border-radius: 0 !important;
    }

    table {
        font-size: 12px;
    }
}

    </style>
</head>

<body>
    <nav class="navbar">
        <div class="navbar-left">
            <img src="{% static 'images/logo.png.jpg' %}" alt="SuchiGo Logo" class="navbar-logo">
            <div class="logo-text">SuchiGo</div>
        </div>
        <div class="menu-toggle" id="menuToggle">
            <span></span>
            <span></span>
            <span></span>
        </div>
        <ul class="navbar-links" id="navbarLinks">
            {% if request.user.role == 1 %}
            <li><a href="{% url 'waste_collector:waste_collector_dashboard' %}" data-page="home">Home</a></li>
            {% else %}
            <li><a href="{% url 'super_admin_dashboard:super_admin_dashboard' %}" data-page="home">Home</a></li>
            {% endif %}

            <li><a href="{% url 'super_admin_dashboard:view_collected_data' %}" class="active"
                    data-page="Collected Data">Collected
                    Data</a></li>
            <li><a href="{% url 'authentication:logout' %}" data-page="logout">Logout</a></li>
        </ul>
    </nav>
    <div class="loading-overlay" id="loadingOverlay">
        <div class="loading-spinner"></div>
    </div>

    <div class="container">
        <div class="header">
            <h2>♻️ Collected Waste Records</h2>
        </div>

        <div class="content">
            <!-- Stats Cards -->
            <div class="stats-container">
                <div class="stat-card">
                    <div class="stat-number" id="totalRecords">0</div>
                    <div class="stat-label">Total Records</div>
                </div>
                <div class="stat-card">
                    <div class="stat-number" id="totalKG">0 KG</div>
                    <div class="stat-label">Total Weight</div>
                </div>
                <div class="stat-card">
                    <div class="stat-number" id="totalAmount">₹0</div>
                    <div class="stat-label">Total Amount</div>
                </div>
                <div class="stat-card">
                    <div class="stat-number" id="activeCollectors">0</div>
                    <div class="stat-label">Active Collectors</div>
                </div>
            </div>

            <!-- Filter Form -->
            <!-- DEBUG: Districts: {{ districts|length }}, LocalBodies: {{ localbodies|length }} -->
            <div class="filter-container" style="padding: 25px; background: #f8f9fa; border-bottom: 1px solid #e9ecef; margin: 20px 0; border-radius: 10px;">
                <form id="filterForm" method="GET" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 15px; align-items: end;">
                    <div>
                        <label for="district" style="display: block; margin-bottom: 5px; font-weight: 600; color: #2c3e50;">🏛️ District</label>
                        <select name="district" id="district" style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 5px; font-size: 14px;">
                            <option value="">All Districts</option>
                            {% for district in districts %}
                                <option value="{{ district.id }}" {% if selected_district == district.id|stringformat:"s" %}selected{% endif %}>
                                    {{ district.name }}
                                </option>
                            {% endfor %}
                        </select>
                    </div>
                    
                    <div>
                        <label for="localbody" style="display: block; margin-bottom: 5px; font-weight: 600; color: #2c3e50;">🏘️ Local Body</label>
                        <select name="localbody" id="localbody" style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 5px; font-size: 14px;">
                            <option value="">All Local Bodies</option>
                            {% for localbody in localbodies %}
                                <option value="{{ localbody.id }}" {% if selected_localbody == localbody.id|stringformat:"s" %}selected{% endif %}>
                                    {{ localbody.name }}
                                </option>
                            {% endfor %}
                        </select>
                    </div>
                    
                    <div>
                        <label for="phone" style="display: block; margin-bottom: 5px; font-weight: 600; color: #2c3e50;">📞 Phone</label>
                        <input type="text" name="phone" id="phone" placeholder="Enter phone number" 
                               value="{{ selected_phone }}" 
                               style="width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 5px; font-size: 14px;">
                    </div>
                    
                    <div>
                        <label for="from_date" style="display: block; margin-bottom: 5px; font-weight: 600; color: #2c3e50;">📅 From Date</label>
