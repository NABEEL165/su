    <script>
        const video = document.getElementById('video');
        const canvas = document.getElementById('canvas');
        const preview = document.getElementById('preview');
        const photoSuccess = document.getElementById('photo-success');
        const captureBtn = document.querySelector('.capture-btn');
        const cameraStatus = document.querySelector('.camera-status');

        // Billing elements
        const localbodyName = document.getElementById('localbody-name');
        const ratePerKg = document.getElementById('rate-per-kg');
        const weightValue = document.getElementById('weight-value');
        const totalAmount = document.getElementById('total-amount');
        const walletBalance = document.getElementById('wallet-balance');
        const walletPaymentRow = document.getElementById('wallet-payment-row');
        const walletPaymentAmount = document.getElementById('wallet-payment-amount');
        const remainingBalanceRow = document.getElementById('remaining-balance-row');
        const remainingBalance = document.getElementById('remaining-balance');
        const kgInput = document.querySelector('input[name="kg"]');
        const bagsInput = document.querySelector('input[name="number_of_bags"]');
        const localbodySelect = document.querySelector('select[name="localbody"]');
        const customerSelect = document.querySelector('select[name="customer"]');
        const payWithWalletBtn = document.getElementById('pay-with-wallet-btn');

        // Local body rates data (passed from the server)
        let localbodyRates = {};

        // Parse local body rates from JSON
        document.addEventListener('DOMContentLoaded', function () {
            try {
                const ratesElement = document.getElementById('localbody-rates-json');
                if (ratesElement) {
                    localbodyRates = JSON.parse(ratesElement.textContent);
                }
            } catch (e) {
                console.error('Error parsing local body rates:', e);
            }
        });

        // ═══════════════════════════════════════════════════════════════
        // BILLING NUMBER GENERATOR  (new code – nothing existing changed)
        // Generates a sequential bill number per session, e.g. BILL-0001
        // If the Django template provides {{ billing_number }} it will be
        // used; otherwise a session-based counter is used as fallback.
        // ═══════════════════════════════════════════════════════════════
        (function initBillingNumber() {
            // 1. Prefer server-supplied number injected via Django template.
            //    Add  {{ billing_number|default:'' }}  to your view context
            //    and it will be picked up automatically here.
            const serverNumber = "{{ billing_number|default:'' }}";

            let displayNumber;

            if (serverNumber && serverNumber.trim() !== '') {
                // Server gave us a real number — format & use it
                const numeric = parseInt(serverNumber, 10);
                displayNumber = 'BILL-' + String(isNaN(numeric) ? serverNumber : numeric).padStart(4, '0');
            } else {
                // Fallback: generate a session-scoped sequential number
                // stored in sessionStorage so it increments across
                // entries in the same browser session.
                let counter = parseInt(sessionStorage.getItem('suchigo_bill_counter') || '0', 10);
                counter += 1;
                sessionStorage.setItem('suchigo_bill_counter', counter);
                displayNumber = 'BILL-' + String(counter).padStart(4, '0');
            }

            // Render into the badge as soon as DOM is ready
            document.addEventListener('DOMContentLoaded', function () {
                const el = document.getElementById('billing-number-text');
                if (el) el.textContent = displayNumber;

                // Also expose it for any downstream JS that may need it
                window.currentBillingNumber = displayNumber;
            });
        })();
        // ═══════════════════════════════════════════════════════════════

        // Initialize billing information
        function updateBillingInfo() {
            // Update local body name
            if (localbodySelect && localbodySelect.options[localbodySelect.selectedIndex]) {
                localbodyName.textContent = localbodySelect.options[localbodySelect.selectedIndex].text || '-';
            }

            // Update rate per kg based on selected local body
            if (localbodySelect && localbodySelect.value) {
                const localbodyId = localbodySelect.value;
                const rate = 40.00;
                ratePerKg.textContent = '₹' + rate.toFixed(2);
            }

            // Update weight value
            if (kgInput) {
                const weight = parseFloat(kgInput.value) || 0;
                weightValue.textContent = weight.toFixed(2) + ' KG';

                // Calculate total amount
                const rate = parseFloat(ratePerKg.textContent.replace('₹', '')) || 40.00;
                const total = weight * rate;
                totalAmount.textContent = '₹' + total.toFixed(2);

                // Update payment options when total amount changes
                updateWalletButtons();
                updatePaymentOptions();
            }
        }

        // Add event listeners for real-time updates
        if (kgInput) {
            kgInput.addEventListener('input', updateBillingInfo);
        }

        if (bagsInput) {
            bagsInput.addEventListener('input', function () {
                const bags = parseInt(bagsInput.value) || 0;
                const calculatedWeight = bags * 1;
                if (kgInput) {
                    kgInput.value = calculatedWeight;
                    kgInput.classList.add('auto-filled');
                    updateBillingInfo();
                }
            });
        }

        if (localbodySelect) {
            localbodySelect.addEventListener('change', updateBillingInfo);
        }

        if (customerSelect) {
            customerSelect.addEventListener('change', function () {
                fetchCustomerWalletBalance();
            });
        }

        // Simple wallet balance display
        function fetchCustomerWalletBalance() {
            if (!customerSelect || !customerSelect.value) {
                walletBalance.textContent = '₹0.00';
                updateWalletButtons();
                return;
            }

            const simulatedBalance = (Math.random() * 5000).toFixed(2);
            walletBalance.textContent = '₹' + simulatedBalance;
            updateWalletButtons();
            updatePaymentOptions();
        }

        // Update wallet buttons based on balance and total amount
        function updateWalletButtons() {
            const balanceText = walletBalance.textContent.replace('₹', '');
            const balance = parseFloat(balanceText) || 0;
            const totalText = totalAmount.textContent.replace('₹', '');
            const total = parseFloat(totalText) || 0;

            if (customerSelect && customerSelect.value && balance > 0 && total > 0) {
                if (balance >= total) {
                    payWithWalletBtn.style.display = 'inline-flex';
                    payWithWalletBtn.style.opacity = '1';
                    payWithWalletBtn.style.pointerEvents = 'auto';
                    payWithWalletBtn.disabled = false;
                    payWithWalletBtn.innerHTML = '<i class="fas fa-wallet"></i> Pay with Wallet';
                } else {
                    payWithWalletBtn.style.display = 'none';
                }
            } else {
                payWithWalletBtn.style.display = 'none';
            }
        }

        // Update payment options display
        function updatePaymentOptions() {
            const balanceText = walletBalance.textContent.replace('₹', '');
            const balance = parseFloat(balanceText) || 0;
            const totalText = totalAmount.textContent.replace('₹', '');
            const total = parseFloat(totalText) || 0;

            if (balance > 0 && total > 0) {
                if (balance >= total) {
                    walletPaymentRow.style.display = 'flex';
                    walletPaymentAmount.textContent = '₹' + total.toFixed(2);
                    remainingBalanceRow.style.display = 'none';
                } else {
                    walletPaymentRow.style.display = 'flex';
                    walletPaymentAmount.textContent = '₹' + balance.toFixed(2);
                    remainingBalanceRow.style.display = 'flex';
                    remainingBalance.textContent = '₹' + (total - balance).toFixed(2);
                }
            } else {
                walletPaymentRow.style.display = 'none';
                remainingBalanceRow.style.display = 'none';
            }
        }

        // Initialize billing info on page load
        document.addEventListener('DOMContentLoaded', function () {
            highlightAutofilledFields();

            setTimeout(function () {
                updateBillingInfo();
                fetchCustomerWalletBalance();
            }, 100);
        });

        function highlightAutofilledFields() {
            const urlParams = new URLSearchParams(window.location.search);
            const customerId = urlParams.get('customer_waste_info_id');

            if (customerId) {
                const inputs = document.querySelectorAll('input, select, textarea');
                inputs.forEach(input => {
                    if (input.value && input.value.trim() !== '') {
                        input.classList.add('auto-filled');
                    }
                });
            }
        }

        const style = document.createElement('style');
        style.textContent = `
            @keyframes slideIn {
                from { transform: translateX(100%); opacity: 0; }
                to { transform: translateX(0); opacity: 1; }
            }
            @keyframes slideOut {
                from { transform: translateX(0); opacity: 1; }
                to { transform: translateX(100%); opacity: 0; }
            }
        `;
        document.head.appendChild(style);

        const constraints = {
            video: {
                facingMode: 'environment'
            }
        };

        navigator.mediaDevices.getUserMedia(constraints)
            .then(stream => {
                video.srcObject = stream;
                cameraStatus.textContent = '✅ Camera active. Point at the waste to capture.';
                if (captureBtn) {
                    captureBtn.style.display = 'inline-block';
                }
            })
            .catch(err => {
                console.warn('Rear camera not available, trying default camera:', err);

                const fallbackConstraints = {
                    video: true
                };

                navigator.mediaDevices.getUserMedia(fallbackConstraints)
                    .then(stream => {
                        video.srcObject = stream;
                        cameraStatus.textContent = '✅ Camera active. Adjust angle as needed.';
                        if (captureBtn) {
                            captureBtn.style.display = 'inline-block';
                        }
                    })
                    .catch(fallbackErr => {
                        console.error('Camera access error:', fallbackErr);
                        cameraStatus.innerHTML =
                            '<span style="color: red;">❌ Camera access denied. Please enable camera permission.</span>';

                        if (captureBtn) {
                            captureBtn.style.display = 'none';
                        }
                    });
            });

        function capturePhoto() {
            if (video.paused || video.ended) {
                alert('Please wait for the video to load before capturing a photo.');
                return;
            }

            canvas.width = video.videoWidth;
            canvas.height = video.videoHeight;

            const context = canvas.getContext('2d');
            context.drawImage(video, 0, 0, canvas.width, canvas.height);

            const dataURL = canvas.toDataURL('image/jpeg', 0.8);
            document.getElementById('photo_data').value = dataURL;

            preview.src = dataURL;
            preview.style.display = 'block';
            preview.style.animation = 'fadeIn 0.4s ease-in-out';

            photoSuccess.style.display = 'flex';

            if (captureBtn) {
                captureBtn.innerHTML = '<i class="fas fa-check"></i> Photo Captured – Retake?';
                captureBtn.style.background = '#333';
            }
        }

        function sharePage() {
            if (navigator.share) {
                navigator.share({
                    title: 'SuchiGo - Waste Collection Entry',
                    text: 'Capture and document waste collection entries',
                    url: window.location.href
                }).catch(console.error);
            } else {
                alert('Sharing is not supported in your browser. Copy the URL: ' + window.location.href);
            }
        }

        function showAbout() {
            alert('SuchiGo Waste Management System\n\nThis page allows you to capture and document waste collection entries with photos for sustainable waste management.');
        }

        function openPaymentModal() {
            const totalText = totalAmount.textContent.replace('₹', '');
            const total = parseFloat(totalText) || 0;

            document.getElementById('modalAmount').textContent = `₹${total.toFixed(2)}`;
            document.getElementById('paymentModal').style.display = 'block';

            selectedModalPayment = '';
            document.getElementById('proceedPaymentBtn').disabled = true;
            document.getElementById('proceedPaymentBtn').textContent = 'Proceed with Payment';

            document.querySelectorAll('.payment-option').forEach(option => {
                option.classList.remove('selected');
            });
        }

        function closePaymentModal() {
            document.getElementById('paymentModal').style.display = 'none';
        }

        window.onclick = function (event) {
            const modal = document.getElementById('paymentModal');
            if (event.target === modal) {
                closePaymentModal();
            }
        }

        let selectedModalPayment = '';

        function selectModalPayment(method) {
            document.querySelectorAll('.payment-option').forEach(option => {
                option.classList.remove('selected');
            });

            event.currentTarget.classList.add('selected');
            selectedModalPayment = method;

            const proceedBtn = document.getElementById('proceedPaymentBtn');
            proceedBtn.disabled = false;
            proceedBtn.textContent = `Proceed with ${method.charAt(0).toUpperCase() + method.slice(1)} Payment`;
        }

        function processModalPayment() {
            if (!selectedModalPayment) {
                alert('Please select a payment method.');
                return;
            }

            const totalText = totalAmount.textContent.replace('₹', '');
            const total = parseFloat(totalText) || 0;

            switch (selectedModalPayment) {
                case 'wallet':
                    if (confirm(`Confirm payment of ₹${total.toFixed(2)} from wallet?`)) {
                        alert(`Processing wallet payment of ₹${total.toFixed(2)}...`);
                        document.querySelector('form').submit();
                    }
                    break;

                case 'razorpay':
                    const selectedOption = customerSelect.options[customerSelect.selectedIndex];
                    const customerId = customerSelect.value;
                    let wasteInfoId = selectedOption.getAttribute('data-waste-info-id');

                    if (wasteInfoId && wasteInfoId !== 'None' && wasteInfoId !== '' && wasteInfoId !== 'undefined') {
                        window.location.href = `/payments/initiate/${wasteInfoId}/`;
                    } else if (customerId) {
                        window.location.href = `/payments/initiate-by-user/${customerId}/`;
                    } else {
                        alert('Please select a customer first.');
                    }
                    break;

                case 'cash':
                    if (confirm('Mark this collection as paid with cash?')) {
                        alert('Recording cash payment...');
                        document.querySelector('form').submit();
                    }
                    break;
            }
        }

        function payWithWallet() {
            const balanceText = walletBalance.textContent.replace('₹', '');
            const balance = parseFloat(balanceText) || 0;
            const totalText = totalAmount.textContent.replace('₹', '');
            const total = parseFloat(totalText) || 0;

            if (balance >= total) {
                if (confirm(`Confirm payment of ₹${total.toFixed(2)} from wallet?`)) {
                    processWalletPayment(total);
                }
            } else {
                alert('Insufficient wallet balance. Please add funds to your wallet.');
            }
        }

        function processWalletPayment(amount) {
            alert('Processing payment of ₹' + amount.toFixed(2) + ' from wallet...');
            document.querySelector('form').submit();
        }

        document.addEventListener('DOMContentLoaded', function () {
            const addWalletBtn = document.getElementById('add-wallet-btn');

            function updateWalletButton() {
                if (customerSelect && customerSelect.value && addWalletBtn) {
                    const customerId = customerSelect.value;
                    const selectedOption = customerSelect.options[customerSelect.selectedIndex];
                    const wasteInfoId = selectedOption.getAttribute('data-waste-info-id');

                    addWalletBtn.style.opacity = '1';
                    addWalletBtn.style.pointerEvents = 'auto';
                    addWalletBtn.onclick = null;

                    if (wasteInfoId && wasteInfoId !== 'None' && wasteInfoId !== '' && wasteInfoId !== 'undefined') {
                        addWalletBtn.href = `/payments/initiate/${wasteInfoId}/`;
                    } else {
                        addWalletBtn.href = `/payments/initiate-by-user/${customerId}/`;
                    }
                } else if (addWalletBtn) {
                    addWalletBtn.href = 'javascript:void(0)';
                    addWalletBtn.style.opacity = '0.5';
                    addWalletBtn.style.pointerEvents = 'none';
                    addWalletBtn.onclick = function () { showNoCustomerAlert(); };
                }
            }

            if (customerSelect) {
                customerSelect.addEventListener('change', updateWalletButton);
            }

            updateWalletButton();
        });

        function showNoCustomerAlert() {
            alert('Please select a customer first before adding wallet funds. No customer waste information is available for this entry.');
        }

        // ═══════════════════════════════════════════════════════════════════
        // GENERATE INVOICE PDF  (newly added – no existing code was changed)
        //
        // Collects all values already displayed in the Billing Information
        // section and renders a professional A4 invoice using jsPDF.
        // ═══════════════════════════════════════════════════════════════════
        function generateInvoicePDF() {
            const { jsPDF } = window.jspdf;

            // ── Collect data from the page ──────────────────────────────
            const billNumber   = (document.getElementById('billing-number-text')  || {}).textContent || 'BILL-0001';
            const localbody    = (document.getElementById('localbody-name')        || {}).textContent || '-';
            const rateText     = (document.getElementById('rate-per-kg')           || {}).textContent || '₹40.00';
            const weightText   = (document.getElementById('weight-value')          || {}).textContent || '0.00 KG';
            const totalText    = (document.getElementById('total-amount')          || {}).textContent || '₹0.00';
            const rate         = rateText.replace('₹', '').trim();
            const weight       = weightText.replace(' KG', '').trim();
            const total        = totalText.replace('₹', '').trim();

            // Customer info
            const custSel      = document.querySelector('select[name="customer"]');
            const customerName = custSel && custSel.options[custSel.selectedIndex]
                                 ? custSel.options[custSel.selectedIndex].text
                                 : 'N/A';

            // Ward, location
            const wardInput    = document.querySelector('input[name="ward"], select[name="ward"]');
            const ward         = wardInput ? wardInput.value || '-' : '-';
            const locInput     = document.querySelector('input[name="location"], select[name="location"]');
            const location     = locInput  ? locInput.value  || '-' : '-';
            const buildingEl   = document.querySelector('input[name="building_no"]');
            const building     = buildingEl ? buildingEl.value || '-' : '-';
            const streetEl     = document.querySelector('input[name="street_name"]');
            const street       = streetEl  ? streetEl.value  || '-' : '-';
            const bagsEl       = document.querySelector('input[name="number_of_bags"]');
            const bags         = bagsEl    ? bagsEl.value    || '0' : '0';
            const paymentEl    = document.querySelector('select[name="payment_method"]');
            const paymentMethod = paymentEl && paymentEl.options[paymentEl.selectedIndex]
                                  ? paymentEl.options[paymentEl.selectedIndex].text
                                  : 'N/A';

            const now          = new Date();
            const dateStr      = now.toLocaleDateString('en-IN', { day:'2-digit', month:'short', year:'numeric' });
            const timeStr      = now.toLocaleTimeString('en-IN', { hour:'2-digit', minute:'2-digit' });

            // ── Build PDF ───────────────────────────────────────────────
            const doc = new jsPDF({ unit: 'mm', format: 'a4', orientation: 'portrait' });
            const pw  = doc.internal.pageSize.getWidth();   // 210
            const ph  = doc.internal.pageSize.getHeight();  // 297

            // Helper colours (RGB)
            const GREEN  = [76, 175, 80];
            const BLUE   = [33, 150, 243];
            const DKGRAY = [51, 51, 51];
            const LTGRAY = [245, 247, 250];
            const WHITE  = [255, 255, 255];
            const BORDER = [224, 224, 224];

            // ── Header gradient band ────────────────────────────────────
            doc.setFillColor(...GREEN);
            doc.rect(0, 0, pw, 38, 'F');
            doc.setFillColor(...BLUE);
            doc.rect(pw * 0.55, 0, pw * 0.45, 38, 'F');

            // Company name
            doc.setTextColor(...WHITE);
            doc.setFontSize(22);
            doc.setFont('helvetica', 'bold');
            doc.text('SuchiGo', 14, 17);

            doc.setFontSize(9);
            doc.setFont('helvetica', 'normal');
            doc.text('Sustainable Waste Management', 14, 24);
            doc.text('info@suchigo.in  |  www.suchigo.in', 14, 30);

            // INVOICE label top-right
            doc.setFontSize(20);
            doc.setFont('helvetica', 'bold');
            doc.text('INVOICE', pw - 14, 18, { align: 'right' });
            doc.setFontSize(9);
            doc.setFont('helvetica', 'normal');
            doc.text(billNumber, pw - 14, 26, { align: 'right' });
            doc.text(dateStr + '  ' + timeStr, pw - 14, 32, { align: 'right' });

            // ── Info cards row ──────────────────────────────────────────
            let y = 48;
            const cardW = (pw - 28 - 8) / 2;   // two cards with 8mm gap, 14mm margins

            // Card 1 – Bill To
            doc.setFillColor(...LTGRAY);
            doc.roundedRect(14, y, cardW, 38, 3, 3, 'F');
            doc.setTextColor(...GREEN);
            doc.setFontSize(8);
            doc.setFont('helvetica', 'bold');
            doc.text('BILL TO', 18, y + 7);
            doc.setTextColor(...DKGRAY);
            doc.setFont('helvetica', 'bold');
            doc.setFontSize(10);
            doc.text(customerName, 18, y + 14);
            doc.setFont('helvetica', 'normal');
            doc.setFontSize(8.5);
            doc.text('Building: ' + building, 18, y + 21);
            doc.text('Street: '   + street,   18, y + 27);
            doc.text('Ward: '     + ward,     18, y + 33);

            // Card 2 – Collection Details
            const c2x = 14 + cardW + 8;
            doc.setFillColor(...LTGRAY);
            doc.roundedRect(c2x, y, cardW, 38, 3, 3, 'F');
            doc.setTextColor(...BLUE);
            doc.setFontSize(8);
            doc.setFont('helvetica', 'bold');
            doc.text('COLLECTION DETAILS', c2x + 4, y + 7);
            doc.setTextColor(...DKGRAY);
            doc.setFont('helvetica', 'normal');
            doc.setFontSize(8.5);
            doc.text('Local Body : ' + localbody,      c2x + 4, y + 14);
            doc.text('Location   : ' + location,       c2x + 4, y + 20);
            doc.text('Bags       : ' + bags + ' bag(s)', c2x + 4, y + 26);
            doc.text('Payment    : ' + paymentMethod,  c2x + 4, y + 32);

            // ── Line items table ────────────────────────────────────────
            y += 46;

            // Table header
            doc.setFillColor(...GREEN);
            doc.rect(14, y, pw - 28, 9, 'F');
            doc.setTextColor(...WHITE);
            doc.setFontSize(8.5);
            doc.setFont('helvetica', 'bold');
            const cols = { desc: 16, qty: 90, rate: 120, amt: 165 };
            doc.text('#',           cols.desc, y + 6);
            doc.text('Description', cols.desc + 6, y + 6);
            doc.text('Weight',      cols.qty,   y + 6);
            doc.text('Rate / KG',   cols.rate,  y + 6);
            doc.text('Amount',      cols.amt,   y + 6);
            y += 9;

            // Table row 1 – Waste Collection
            doc.setFillColor(...WHITE);
            doc.rect(14, y, pw - 28, 10, 'F');
            doc.setDrawColor(...BORDER);
            doc.setLineWidth(0.3);
            doc.rect(14, y, pw - 28, 10, 'S');
            doc.setTextColor(...DKGRAY);
            doc.setFont('helvetica', 'normal');
            doc.setFontSize(9);
            doc.text('01',                     cols.desc,     y + 7);
            doc.text('Waste Collection Service', cols.desc + 6, y + 7);
            doc.text(weight + ' KG',           cols.qty,      y + 7);
            doc.text('Rs.' + rate,             cols.rate,     y + 7);
            doc.text('Rs.' + total,            cols.amt,      y + 7);
            y += 10;

            // Empty filler row
            doc.setFillColor(250, 252, 250);
            doc.rect(14, y, pw - 28, 8, 'F');
            doc.rect(14, y, pw - 28, 8, 'S');
            y += 8;

            // ── Totals block ────────────────────────────────────────────
            y += 6;
            const totW  = 80;
            const totX  = pw - 14 - totW;

            // Sub-total row
            doc.setDrawColor(...BORDER);
            doc.setLineWidth(0.25);
            doc.setFillColor(...LTGRAY);
            doc.rect(totX, y, totW, 8, 'F');
            doc.rect(totX, y, totW, 8, 'S');
            doc.setFont('helvetica', 'normal');
            doc.setFontSize(8.5);
            doc.setTextColor(...DKGRAY);
            doc.text('Sub-total',        totX + 4,  y + 5.5);
            doc.text('Rs.' + total,      totX + totW - 4, y + 5.5, { align: 'right' });
            y += 8;

            // Tax row (0%)
            doc.setFillColor(...WHITE);
            doc.rect(totX, y, totW, 8, 'F');
            doc.rect(totX, y, totW, 8, 'S');
            doc.text('GST / Tax (0%)',   totX + 4,  y + 5.5);
            doc.text('Rs.0.00',          totX + totW - 4, y + 5.5, { align: 'right' });
            y += 8;

            // TOTAL row
            doc.setFillColor(...GREEN);
            doc.rect(totX, y, totW, 10, 'F');
            doc.setTextColor(...WHITE);
            doc.setFont('helvetica', 'bold');
            doc.setFontSize(10);
            doc.text('TOTAL',            totX + 4,  y + 7);
            doc.text('Rs.' + total,      totX + totW - 4, y + 7, { align: 'right' });
            y += 16;

            // ── Payment status pill ─────────────────────────────────────
            doc.setFillColor(232, 245, 232);
            doc.roundedRect(14, y, 60, 9, 2, 2, 'F');
            doc.setTextColor(...GREEN);
            doc.setFont('helvetica', 'bold');
            doc.setFontSize(8.5);
            doc.text('Payment Method: ' + paymentMethod, 17, y + 6);

            // ── Notes box ───────────────────────────────────────────────
            y += 16;
            doc.setDrawColor(...BORDER);
            doc.setFillColor(250, 253, 250);
            doc.roundedRect(14, y, pw - 28, 22, 3, 3, 'FD');
            doc.setTextColor(...GREEN);
            doc.setFont('helvetica', 'bold');
            doc.setFontSize(8);
            doc.text('NOTES', 18, y + 7);
            doc.setTextColor(100, 100, 100);
            doc.setFont('helvetica', 'normal');
            doc.setFontSize(8);
            doc.text('Thank you for contributing to a cleaner environment!', 18, y + 13);
            doc.text('For queries: support@suchigo.in  |  This is a computer-generated invoice.', 18, y + 19);

            // ── Footer bar ──────────────────────────────────────────────
            doc.setFillColor(...GREEN);
            doc.rect(0, ph - 14, pw, 14, 'F');
            doc.setTextColor(...WHITE);
            doc.setFontSize(8);
            doc.setFont('helvetica', 'normal');
            doc.text('SuchiGo Waste Management  |  www.suchigo.in', pw / 2, ph - 6, { align: 'center' });

            // ── Watermark-style diagonal text ───────────────────────────
            doc.setTextColor(76, 175, 80, 0.06);   // very faint green
            doc.setFontSize(52);
            doc.setFont('helvetica', 'bold');
            doc.saveGraphicsState && doc.saveGraphicsState();
            doc.text('SuchiGo', pw / 2, ph / 2, { align: 'center', angle: 45 });
            doc.loadGraphicsState && doc.loadGraphicsState();

            // ── Save ────────────────────────────────────────────────────
            const fileName = 'SuchiGo_Invoice_' + billNumber + '_' + dateStr.replace(/ /g, '-') + '.pdf';
            doc.save(fileName);
        }
        // ═══════════════════════════════════════════════════════════════
    </script>

</body>

</html>
